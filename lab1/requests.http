### ==========================================
### AUTHENTICATION ENDPOINTS
### ==========================================

### Register a new user
POST http://localhost:8080/api/auth/register
Content-Type: application/json

{
  "username": "user1",
  "password": "password123"
}

### Register an admin user
POST http://localhost:8080/api/auth/register
Content-Type: application/json

{
  "username": "admin1",
  "password": "password123"
}

### Login and get JWT token
POST http://localhost:8080/api/auth/login
Content-Type: application/json

{
  "username": "user1",
  "password": "password123"
}

### ==========================================
### CUSTOMER API V1 (Requires Authentication)
### ==========================================

### Create a new customer (ADMIN only)
# First, login as admin and use the token from response
POST http://localhost:8080/api/v1/customers
Content-Type: application/json
Authorization: Bearer YOUR_ADMIN_TOKEN_HERE

{
  "firstName": "Ivan",
  "lastName": "Ivanov",
  "email": "ivan@example.com"
}

### Get all customers with pagination (USER or ADMIN)
GET http://localhost:8080/api/v1/customers?page=0&size=10&sort=id,asc
Authorization: Bearer YOUR_TOKEN_HERE

### Get all customers with custom sorting
GET http://localhost:8080/api/v1/customers?page=0&size=5&sort=firstName,desc
Authorization: Bearer YOUR_TOKEN_HERE

### Filter customers by firstName
GET http://localhost:8080/api/v1/customers?page=0&size=10&firstName=Ivan
Authorization: Bearer YOUR_TOKEN_HERE

### Filter customers by lastName
GET http://localhost:8080/api/v1/customers?page=0&size=10&lastName=Ivanov
Authorization: Bearer YOUR_TOKEN_HERE

### Filter customers by email
GET http://localhost:8080/api/v1/customers?page=0&size=10&email=@gmail.com
Authorization: Bearer YOUR_TOKEN_HERE

### Combined filtering with pagination and sorting
GET http://localhost:8080/api/v1/customers?page=0&size=10&sort=lastName,asc&firstName=Ivan&lastName=Ivanov
Authorization: Bearer YOUR_TOKEN_HERE

### Get customer by ID (USER or ADMIN)
GET http://localhost:8080/api/v1/customers/1
Authorization: Bearer YOUR_TOKEN_HERE

### Update a customer (ADMIN only)
PUT http://localhost:8080/api/v1/customers/1
Content-Type: application/json
Authorization: Bearer YOUR_ADMIN_TOKEN_HERE

{
  "firstName": "Ivan Updated",
  "lastName": "Ivanov Updated",
  "email": "ivan.updated@example.com"
}

### Delete a customer (ADMIN only)
DELETE http://localhost:8080/api/v1/customers/1
Authorization: Bearer YOUR_ADMIN_TOKEN_HERE

### ==========================================
### ASYNC JMS ENDPOINTS (Lab 3)
### ==========================================

### Create customer with async email notification (ADMIN only)
# After creation, welcome email will be sent asynchronously via JMS
POST http://localhost:8080/api/v1/customers
Content-Type: application/json
Authorization: Bearer YOUR_ADMIN_TOKEN_HERE

{
  "firstName": "Async",
  "lastName": "User",
  "email": "async.user@example.com"
}

### Generate customer report asynchronously (ADMIN only)
# Request is queued and processed in background
# Returns 202 Accepted with requestId
POST http://localhost:8080/api/v1/customers/reports/generate?type=customer-list&format=PDF
Authorization: Bearer YOUR_ADMIN_TOKEN_HERE

### Generate report in CSV format
POST http://localhost:8080/api/v1/customers/reports/generate?type=customer-list&format=CSV
Authorization: Bearer YOUR_ADMIN_TOKEN_HERE

### Generate report with custom type
POST http://localhost:8080/api/v1/customers/reports/generate?type=active-customers&format=PDF
Authorization: Bearer YOUR_ADMIN_TOKEN_HERE

### ==========================================
### TEST WITHOUT AUTHENTICATION (Should fail)
### ==========================================

### This should return 401 Unauthorized
GET http://localhost:8080/api/v1/customers

### This should return 403 Forbidden (USER trying admin operation)
POST http://localhost:8080/api/v1/customers
Content-Type: application/json
Authorization: Bearer YOUR_USER_TOKEN_HERE

{
  "firstName": "Test",
  "lastName": "Testov",
  "email": "test@example.com"
}
